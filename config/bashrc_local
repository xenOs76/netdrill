
export LC_ALL=UTF8

eval "$(direnv hook bash)"
eval "$(doggo completions bash)"
eval "$(https-wrench completion bash)"
eval "$(starship init bash)"
eval "$(zoxide init bash)"

alias cd='z'
alias ..='cd ..'

alias l='ls -alh'
alias l='ls -alh'
alias la='eza -a'
alias ll='eza -lhaa --git --git-repos --no-user --octal-permissions --no-permissions --icons --time-style='\''+%Y-%m-%d %H:%M'\'''
alias lla='eza -la'
alias lldirnewest='llnewest -D'
alias llnewest='eza --sort=time --reverse --oneline --git-ignore --changed --long --no-filesize --no-user --no-permissions --time-style="+%y-%m-%d %h:%m -" --icons=auto'
alias llsize='ll --sort=size --reverse  --total-size'
alias lltime='ll --sort=time --reverse'
alias lltree='eza -lgha --git --git-repos -T --total-size'
alias ls='eza'
alias lt='eza --tree'

alias dig="doggo"
alias doggo-doh="doggo @https://cloudflare-dns.com/dns-query"
alias doggo-tls="doggo @tls://1.1.1.1"

alias apk-install="apk add"
alias jwtinfo-local-token="https-wrench jwtinfo --token-file /var/run/secrets/kubernetes.io/serviceaccount/token"
alias nvim-os76="nix run github:xenos76/os76-nvf"

#
# Aliases for packages to install on demand
#
alias file="apk add -q file && /usr/bin/file"
alias git="apk add -q git && /usr/bin/git"
alias go="apk add -q go && /usr/bin/go"
alias htop="apk add -q htop && /usr/bin/htop"
alias nix="apk add -q nix && /usr/bin/nix --extra-experimental-features nix-command --extra-experimental-features flakes"
alias python="apk add -q python3 && /usr/bin/python"
alias zellij="apk add -q zellij && /usr/bin/zellij"
