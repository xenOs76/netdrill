YELLOW='\033[1;33m'
NOCOLOR='\033[0m'

if ! command -v python >/dev/null 2>&1; then
  echo -e "\n\t${YELLOW}WARNING: ${NOCOLOR}python not installed\n"
  echo -e "\tTo install: apk add python3"
  echo -e "\tThen run: direnv reload"
  return 1
fi

export VIRTUAL_ENV=".venv"
test -d $VIRTUAL_ENV || (echo 'Creating Python venv' && python -m venv $VIRTUAL_ENV && source $VIRTUAL_ENV/bin/activate && pip install -r requirements.txt)
layout python
